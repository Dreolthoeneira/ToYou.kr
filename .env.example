# Supabase Dashboard > Project Settings > API에서 확인합니다.
# publishable/anon key는 브라우저에 포함되어도 되지만 service_role key는 절대 넣지 마세요.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_YOUR_KEY

# GitHub Pages 저장소 경로. 로컬에서는 기본값 / 를 사용합니다.
# VITE_BASE_PATH=/YOUR_REPOSITORY_NAME/
